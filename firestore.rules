rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['vkalvaro1005@gmail.com', 'vishwa10230506@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['stock']) &&
        incoming().stock == existing().stock + (incoming().stock - existing().stock) // Type check implicitly handled by stock update
      );
      
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 200
            && data.description is string && data.description.size() < 5000
            && data.price is number && data.price >= 0
            && data.category is string
            && data.images is list && data.images.size() > 0
            && data.stock is number && data.stock >= 0;
      }
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin(); // Admin updates status or tracking, or deletes old orders
      
      function isValidOrder(data) {
        return data.userId == request.auth.uid
            && data.items is list && data.items.size() > 0
            && data.total is number && data.total >= 0
            && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
            && data.createdAt == request.time;
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      function isValidReview(data) {
        return data.productId is string
            && data.userId == request.auth.uid
            && data.rating is number && data.rating >= 1 && data.rating <= 5
            && data.comment is string && data.comment.size() < 1000
            && data.createdAt == request.time;
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && (
        !incoming().keys().hasAny(['role']) || isAdmin()
      );
    }
  }
}
