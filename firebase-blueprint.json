{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A clothing item in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "price", "category", "images", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's purchase",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "object" },
        "trackingNumber": { "type": "string" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer's feedback on a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role info",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "wishlist": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
